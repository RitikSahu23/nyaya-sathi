# Ollama API Configuration
# Local Development: Completely Free!

# Step 1: Install Ollama from https://ollama.ai
# Step 2: Run: ollama pull mistral
# Step 3: Run: ollama serve (keep this running in a terminal)
# Step 4: Leave this as default (localhost)

# For local development (default):
OLLAMA_API_URL=http://localhost:11434/api/generate

# For cloud deployment (optional):
# If deploying to a server, use your server's Ollama URL:
# OLLAMA_API_URL=https://your-ollama-server.com/api/generate

