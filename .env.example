# Environment Variables

# For Local Development:
# Install Ollama: https://ollama.ai
# Run: ollama pull mistral
# Then: ollama serve
# Leave this commented or set to localhost:
# OLLAMA_API_URL=http://localhost:11434/api/generate

# For Production (Cloud Deployment):
# Set this to your Railway/Cloud Ollama server URL
# Example: OLLAMA_API_URL=https://nyaya-sathi-ollama.railway.app/api/generate
OLLAMA_API_URL=http://localhost:11434/api/generate

